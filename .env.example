# Copy to .env.local and fill in values for local development
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Production site URL (set in Vercel for custom domain)
NEXT_PUBLIC_SITE_URL=https://www.thedesignworkbench.com

# Backend API base URL (required for login/register and dashboard APIs)
BACKEND_API_URL=
