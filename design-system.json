  "components": {
    "button": {
      "padding": {
        "sm": "0.5rem 1rem",
        "md": "0.625rem 1.25rem",
        "lg": "0.75rem 1.5rem",
        "xl": "0.875rem 2rem"
      },
      "borderRadius": "0.5rem",
      "fontWeight": "600",
      "transition": "all 0.2s ease-in-out"
    },
    "card": {
      "padding": "1.5rem",
      "borderRadius": "1rem",
      "shadow": "md",
      "background": "white"
    },
    "input": {
      "padding": "0.625rem 1rem",
      "borderRadius": "0.5rem",
      "border": "1px solid #e5e5e5",
      "fontSize": "1rem"
    }
